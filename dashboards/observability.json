                        "format": "table",
                        "rawQuery": true,
                        "rawSql": "SELECT\r\n  $__timeGroupAlias(ingest_ts, 1m),\r\n  percentile_cont(0.99) WITHIN GROUP (ORDER BY gap) AS \"P99 Ingest Latency\"\r\nFROM (\r\n  SELECT \r\n    ingest_ts,\r\n    EXTRACT(EPOCH FROM (ingest_ts - LAG(ingest_ts) OVER (ORDER BY ingest_ts))) as gap\r\n  FROM iot_raw.raw_events\r\n) as subquery\r\nWHERE $__timeFilter(ingest_ts)\r\nGROUP BY 1\r\nORDER BY 1",
